GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# AssemblyAI streaming diarization (required for one-mic mode). Uses the
# Universal-3 Pro streaming model with speaker labels.
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
# Hint for the expected number of speakers in the room (1-10).
ASSEMBLYAI_MAX_SPEAKERS=2
# Optional: override the streaming model (defaults to u3-rt-pro).
# ASSEMBLYAI_MODEL=u3-rt-pro
# Optional: raise VAD threshold (0-1) in noisy rooms to cut false speech.
# ASSEMBLYAI_VAD_THRESHOLD=0.5
# Turn endpointing — higher = waits longer before finalizing a turn, so it does
# not cut speakers off mid-sentence (AssemblyAI defaults: 0.4 / 400 / 1280).
# ASSEMBLYAI_EOT_CONFIDENCE=0.8
# ASSEMBLYAI_MIN_SILENCE=1000
# ASSEMBLYAI_MAX_SILENCE=3000
# Turns with this many words or fewer are treated as short replies and attributed
# to the other speaker (a brief reply is usually the responder). 0 disables.
# ASSEMBLYAI_SHORT_TURN_WORDS=1
# Log each AssemblyAI turn for debugging: ASSEMBLYAI_DEBUG=1

PORT=3000
