GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# AssemblyAI streaming diarization (required for one-mic mode). Uses the
# Universal-3 Pro streaming model with speaker labels.
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
# Hint for the expected number of speakers in the room (1-10).
ASSEMBLYAI_MAX_SPEAKERS=2
# Optional: override the streaming model (defaults to u3-rt-pro).
# ASSEMBLYAI_MODEL=u3-rt-pro
# Optional: raise VAD threshold (0-1) in noisy rooms to cut false speech.
# ASSEMBLYAI_VAD_THRESHOLD=0.5

PORT=3000

# Local SpeechBrain voiceprint (free, on-device). Used only to resolve short
# turns that AssemblyAI cannot attribute. Requires Python + the deps in
# requirements-speaker-id.txt.
# Path/command for the Python interpreter that has the speaker-ID deps installed.
# Point this at a virtualenv, e.g. .venv/Scripts/python.exe on Windows.
SPEAKER_PYTHON=python
# Cosine-similarity cutoff for "this turn is Me" (0-1, higher = stricter).
SPEECHBRAIN_THRESHOLD=0.65
SPEECHBRAIN_MODEL=speechbrain/spkrec-ecapa-voxceleb
SPEECHBRAIN_DEVICE=cpu
